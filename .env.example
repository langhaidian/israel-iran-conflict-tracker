# GEMINI_API_KEY: Gemini AI API 调用所需的密钥（必填）。
# 在 AI Studio 中会自动从用户密钥中注入。
# 本地开发时，请将此文件复制为 .env.local 并填入你的 API 密钥。
GEMINI_API_KEY="你的_GEMINI_API_KEY"

# GEMINI_MODEL: 使用的 Gemini 模型名称（可选）。
# 默认值为 gemini-3.1-pro-preview，可更换为其他可用模型。
GEMINI_MODEL="gemini-3-flash-preview"

# APP_URL: 应用托管的 URL 地址（可选）。
# AI Studio 会自动注入 Cloud Run 服务的 URL。
# 用于自引用链接、OAuth 回调和 API 端点。
APP_URL="MY_APP_URL"
